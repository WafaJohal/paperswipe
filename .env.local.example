# NextAuth
NEXTAUTH_SECRET=          # Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth  (https://github.com/settings/developers → New OAuth App)
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth  (https://console.cloud.google.com → Credentials → OAuth 2.0)
GOOGLE_ID=
GOOGLE_SECRET=

# Vercel Postgres  (Dashboard → Storage → Connect → .env.local snippet)
POSTGRES_URL=
POSTGRES_PRISMA_URL=      # same as POSTGRES_URL but with ?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING= # direct connection, no pooler — used by Prisma migrations

# Encryption
ENCRYPTION_KEY=           # Exactly 32 characters, e.g.: openssl rand -hex 16
